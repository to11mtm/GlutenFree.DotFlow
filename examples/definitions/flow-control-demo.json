{
  "$schema": "../../Workflow.Core/schema/workflow-definition.json",
  "id": "a1b2c3d4-0000-0000-0000-flow-ctrl-demo",
  "name": "Advanced Flow Control Demo",
  "description": "End-to-end Phase 2.2 showcase — composes ForEach + TryCatch + Condition + Parallel + Throw + Log + SetVariable into a single workflow that demonstrates every major control-flow primitive shipped in Phase 2.2~ 🌟💖",
  "version": "1.0.0",
  "metadata": {
    "phase": "2.2.6",
    "purpose": "end-to-end feature showcase (no external I/O — uses only built-in modules)",
    "scenario": "Batch item processor — iterates a list of integers; each item runs inside a per-iteration error boundary. Items > threshold succeed via a parallel notify+persist; items <= threshold throw and are caught locally so the batch continues~ 🎯",
    "modulesUsed": [
      "builtin.loop.foreach",
      "builtin.trycatch",
      "builtin.condition",
      "builtin.parallel",
      "builtin.throw",
      "builtin.log",
      "builtin.setvariable"
    ],
    "expectedShape": "Start -> ForEach -> TryCatch(try->Condition(true->Parallel[Log,SetVariable] | false->Throw); catch->Log; finally->Log; done) -> SetVariable(summary)"
  },
  "nodes": [
    { "id": "start", "moduleId": "builtin.log", "name": "Start — Announce Batch",
      "properties": { "message": "🚀 Starting batch — threshold={{threshold}}", "level": "Information" },
      "position": { "x": 100, "y": 300 } },
    { "id": "foreach", "moduleId": "builtin.loop.foreach", "name": "ForEach Item in Batch",
      "properties": { "collection": "[1, 2, 3, 4, 5]", "maxIterations": 100, "continueOnError": true },
      "position": { "x": 320, "y": 300 } },
    { "id": "trycatch", "moduleId": "builtin.trycatch", "name": "Per-Item Error Boundary",
      "properties": { "rethrow": false, "catchTypes": [] },
      "position": { "x": 540, "y": 300 } },
    { "id": "condition", "moduleId": "builtin.condition", "name": "Item Above Threshold?",
      "properties": { "condition": "item > threshold" },
      "position": { "x": 760, "y": 300 } },
    { "id": "parallel", "moduleId": "builtin.parallel", "name": "Parallel Notify + Persist",
      "properties": { "branches": "[\"notify\", \"persist\"]", "maxDegreeOfParallelism": 2, "failFast": true },
      "position": { "x": 980, "y": 200 } },
    { "id": "notify_branch", "moduleId": "builtin.log", "name": "Notify Branch",
      "properties": { "message": "📨 Notifying about accepted item", "level": "Information" },
      "position": { "x": 1200, "y": 120 } },
    { "id": "persist_branch", "moduleId": "builtin.setvariable", "name": "Persist Last Accepted",
      "properties": { "name": "last_processed", "value": "accepted" },
      "position": { "x": 1200, "y": 280 } },
    { "id": "throw_low", "moduleId": "builtin.throw", "name": "Throw — Below Threshold",
      "properties": { "errorType": "BelowThreshold", "message": "Item is at or below threshold — skipped", "data": { "reason": "below_threshold" } },
      "position": { "x": 980, "y": 400 } },
    { "id": "catch_handler", "moduleId": "builtin.log", "name": "Catch — Log Skipped Item",
      "properties": { "message": "⚠️ Item skipped: {{error.errorType}} — {{error.message}}", "level": "Warning" },
      "position": { "x": 760, "y": 480 } },
    { "id": "finally_audit", "moduleId": "builtin.log", "name": "Finally — Iteration Audit",
      "properties": { "message": "📋 Iteration done — continuing batch", "level": "Debug" },
      "position": { "x": 760, "y": 600 } },
    { "id": "set_summary", "moduleId": "builtin.setvariable", "name": "Set Summary",
      "properties": { "name": "summary", "value": "all items processed" },
      "position": { "x": 540, "y": 720 } },
    { "id": "end", "moduleId": "builtin.log", "name": "End — Emit Summary",
      "properties": { "message": "🏁 Batch complete — summary={{summary}} last_processed={{last_processed}}", "level": "Information" },
      "position": { "x": 320, "y": 720 } }
  ],
  "connections": [
    { "sourceNodeId": "start",         "sourcePortName": "output",        "targetNodeId": "foreach",        "targetPortName": "input", "comment": "Start -> enter the foreach loop" },
    { "sourceNodeId": "foreach",       "sourcePortName": "loopBody",      "targetNodeId": "trycatch",       "targetPortName": "input", "comment": "Per-iteration: enter the trycatch boundary (LoopExecutor injects item + index into body inputs)" },
    { "sourceNodeId": "trycatch",      "sourcePortName": "try",           "targetNodeId": "condition",      "targetPortName": "input", "comment": "Try-body: evaluate the threshold condition" },
    { "sourceNodeId": "condition",     "sourcePortName": "true",          "targetNodeId": "parallel",       "targetPortName": "input", "comment": "Above threshold -> parallel fan-out" },
    { "sourceNodeId": "parallel",      "sourcePortName": "notify",        "targetNodeId": "notify_branch",  "targetPortName": "input", "comment": "Branch A — notification" },
    { "sourceNodeId": "parallel",      "sourcePortName": "persist",       "targetNodeId": "persist_branch", "targetPortName": "input", "comment": "Branch B — persistence" },
    { "sourceNodeId": "condition",     "sourcePortName": "false",         "targetNodeId": "throw_low",      "targetPortName": "input", "comment": "Below threshold -> throw (caught by enclosing trycatch)" },
    { "sourceNodeId": "trycatch",      "sourcePortName": "catch",         "targetNodeId": "catch_handler",  "targetPortName": "input", "comment": "Catch — log the skipped item; iteration continues" },
    { "sourceNodeId": "trycatch",      "sourcePortName": "finally",       "targetNodeId": "finally_audit",  "targetPortName": "input", "comment": "Finally — runs whether try succeeded or catch handled" },
    { "sourceNodeId": "foreach",       "sourcePortName": "done",          "targetNodeId": "set_summary",    "targetPortName": "input", "comment": "After all iterations finish -> write summary variable" },
    { "sourceNodeId": "set_summary",   "sourcePortName": "previousValue", "targetNodeId": "end",            "targetPortName": "input", "comment": "Final log node" }
  ],
  "variables": {
    "threshold":      { "type": "number", "defaultValue": 2, "description": "Items strictly greater than this value succeed via the parallel branch; items <= are thrown and caught~ 🎯" },
    "last_processed": { "type": "string", "description": "Updated by the persist branch each time an item is accepted~" },
    "summary":        { "type": "string", "description": "Set once the foreach loop completes all iterations~" }
  }
}
