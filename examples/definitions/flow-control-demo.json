{
  "$schema": "../../Workflow.Core/schema/workflow-definition.json",
  "id": "a1b2c3d4-0000-0000-0000-flow-ctrl-demo",
  "name": "Advanced Flow Control Demo",
  "description": "Demonstrates condition branching, try/catch error boundaries, and log/setvariable modules composing cleanly together~ 🌟💖",
  "version": "1.0.0",
  "metadata": {
    "phase": "2.2.6",
    "purpose": "end-to-end feature showcase",
    "noteForAuthors": "Use 'score' variable (number) to drive the condition branch. Set to > 600 for approval path, <= 600 for denial path. Setting 'forceError' to true triggers the throw node inside the try-body~ 🎯"
  },
  "nodes": [
    {
      "id": "start",
      "moduleId": "builtin.log",
      "name": "Start — Log Intake",
      "properties": {
        "message": "🚀 Loan application received — score={{score}}",
        "level": "Information"
      },
      "position": { "x": 100, "y": 200 }
    },

    {
      "id": "trycatch",
      "moduleId": "builtin.trycatch",
      "name": "Safe Processing Boundary",
      "properties": {
        "rethrow": false,
        "catchTypes": []
      },
      "position": { "x": 320, "y": 200 }
    },

    {
      "id": "condition",
      "moduleId": "builtin.condition",
      "name": "Score ≥ 600?",
      "properties": {
        "condition": "score >= 600"
      },
      "position": { "x": 540, "y": 200 }
    },

    {
      "id": "approve",
      "moduleId": "builtin.log",
      "name": "Log Approval",
      "properties": {
        "message": "✅ Application APPROVED — score={{score}}",
        "level": "Information"
      },
      "position": { "x": 760, "y": 100 }
    },

    {
      "id": "set_approved",
      "moduleId": "builtin.setvariable",
      "name": "Set Result = approved",
      "properties": {
        "name": "result",
        "value": "approved"
      },
      "position": { "x": 980, "y": 100 }
    },

    {
      "id": "deny_throw",
      "moduleId": "builtin.throw",
      "name": "Throw — Score Too Low",
      "properties": {
        "errorType": "LowCreditScore",
        "message": "Score {{score}} is below minimum threshold of 600",
        "data": { "score": "{{score}}", "minRequired": 600 }
      },
      "position": { "x": 760, "y": 300 }
    },

    {
      "id": "catch_handler",
      "moduleId": "builtin.log",
      "name": "Log Denial Reason",
      "properties": {
        "message": "❌ Application DENIED — {{error.errorType}}: {{error.message}}",
        "level": "Warning"
      },
      "position": { "x": 760, "y": 440 }
    },

    {
      "id": "set_denied",
      "moduleId": "builtin.setvariable",
      "name": "Set Result = denied",
      "properties": {
        "name": "result",
        "value": "denied"
      },
      "position": { "x": 980, "y": 440 }
    },

    {
      "id": "finally_audit",
      "moduleId": "builtin.log",
      "name": "Audit Log (Finally)",
      "properties": {
        "message": "📋 Processing complete — writing audit trail",
        "level": "Information"
      },
      "position": { "x": 760, "y": 580 }
    },

    {
      "id": "set_processed_at",
      "moduleId": "builtin.setvariable",
      "name": "Set ProcessedAt",
      "properties": {
        "name": "processedAt",
        "value": "{{$utcNow}}"
      },
      "position": { "x": 980, "y": 580 }
    },

    {
      "id": "end",
      "moduleId": "builtin.log",
      "name": "End — Emit Summary",
      "properties": {
        "message": "🏁 Workflow done — result={{result}} processedAt={{processedAt}}",
        "level": "Information"
      },
      "position": { "x": 1200, "y": 200 }
    }
  ],

  "connections": [
    {
      "sourceNodeId": "start",
      "sourcePortName": "output",
      "targetNodeId": "trycatch",
      "targetPortName": "input",
      "comment": "Start → enter error boundary"
    },
    {
      "sourceNodeId": "trycatch",
      "sourcePortName": "try",
      "targetNodeId": "condition",
      "targetPortName": "input",
      "comment": "Try-body: runs score evaluation"
    },
    {
      "sourceNodeId": "condition",
      "sourcePortName": "true",
      "targetNodeId": "approve",
      "targetPortName": "input",
      "comment": "Approval path"
    },
    {
      "sourceNodeId": "approve",
      "sourcePortName": "output",
      "targetNodeId": "set_approved",
      "targetPortName": "input",
      "comment": "Persist approval decision"
    },
    {
      "sourceNodeId": "condition",
      "sourcePortName": "false",
      "targetNodeId": "deny_throw",
      "targetPortName": "input",
      "comment": "Denial path — throw structured error"
    },
    {
      "sourceNodeId": "trycatch",
      "sourcePortName": "catch",
      "targetNodeId": "catch_handler",
      "targetPortName": "input",
      "comment": "Catch block — logs denial reason from WorkflowError"
    },
    {
      "sourceNodeId": "catch_handler",
      "sourcePortName": "output",
      "targetNodeId": "set_denied",
      "targetPortName": "input",
      "comment": "Persist denial decision"
    },
    {
      "sourceNodeId": "trycatch",
      "sourcePortName": "finally",
      "targetNodeId": "finally_audit",
      "targetPortName": "input",
      "comment": "Finally — always runs (audit trail)"
    },
    {
      "sourceNodeId": "finally_audit",
      "sourcePortName": "output",
      "targetNodeId": "set_processed_at",
      "targetPortName": "input",
      "comment": "Record processing timestamp"
    },
    {
      "sourceNodeId": "trycatch",
      "sourcePortName": "done",
      "targetNodeId": "end",
      "targetPortName": "input",
      "comment": "done-port: fires after full try/catch/finally sequence completes"
    }
  ],

  "variables": {
    "score": {
      "type": "number",
      "defaultValue": 720,
      "description": "Credit score to evaluate (>= 600 → approved, < 600 → denied via throw/catch)~ 🎯"
    },
    "result": {
      "type": "string",
      "description": "Set to 'approved' or 'denied' by the workflow~"
    },
    "processedAt": {
      "type": "string",
      "description": "UTC timestamp when processing completed~"
    }
  }
}

