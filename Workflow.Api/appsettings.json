{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistence": {
    "Provider": "sqlite",
    "ConnectionString": ":memory:",
    "Composite": {
      "Workflows": {
        "Provider": "postgres",
        "ConnectionString": "Host=localhost;Database=workflow;Username=workflow;Password=workflow"
      },
      "ExecutionHistory": {
        "Provider": "postgres",
        "ConnectionString": "Host=localhost;Database=workflow;Username=workflow;Password=workflow"
      },
      "Variables": {
        "Provider": "nats",
        "ConnectionString": "nats://localhost:4222"
      }
    }
  },
  "AllowedHosts": "*"
}
