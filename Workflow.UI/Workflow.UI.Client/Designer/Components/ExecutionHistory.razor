@namespace Workflow.UI.Client.Designer.Components
@using Workflow.UI.Client.Api
@using Workflow.UI.Client.Api.Dtos
@inject ExecutionsClient Executions
@inject NavigationManager Nav

<div class="df-history">
    <div class="df-history__title">🕘 Executions</div>
    @if (loading)
    {
        <div class="df-empty">Loading…</div>
    }
    else if (items.Count == 0)
    {
        <div class="df-empty">No executions yet.</div>
    }
    else
    {
        @foreach (var e in items)
        {
            <div class="df-history__item @(e.ExecutionId == SelectedId ? "df-history__item--active" : "")"
                 data-testid="exec-@e.ExecutionId"
                 @onclick="() => OnSelect.InvokeAsync(e.ExecutionId)">
                <span>@IconFor(e.State)</span>
                <span class="df-history__id">@e.ExecutionId.ToString()[..8]…</span>
                <span class="df-history__time">@e.StartedAt.ToString("HH:mm")</span>
                <span class="df-history__dur">@Duration(e)</span>
                <button class="df-btn df-btn--small" data-testid="open-in-monitor" title="Open in Monitor"
                        @onclick:stopPropagation="true" @onclick="() => OpenInMonitor(e.ExecutionId)">📡</button>
            </div>
        }
    }
</div>

@code {
    private readonly List<ExecutionDto> items = new();
    private bool loading = true;

    /// <summary>The workflow whose executions to list.</summary>
    [Parameter, EditorRequired]
    public System.Guid WorkflowId { get; set; }

    /// <summary>The currently-inspected execution (highlighted).</summary>
    [Parameter]
    public System.Guid? SelectedId { get; set; }

    /// <summary>Raised when an execution is selected for inspection.</summary>
    [Parameter]
    public EventCallback<System.Guid> OnSelect { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var page = await Executions.ListAsync(this.WorkflowId);
            this.items.AddRange(page.Items);
        }
        catch (ApiException)
        {
            // Empty state covers the failure; the status bar surfaces API health.
        }
        finally
        {
            this.loading = false;
        }
    }

    private static string IconFor(string state) => state switch
    {
        "Completed" => "✅",
        "Failed" => "❌",
        "Cancelled" => "🛑",
        "Running" => "🔄",
        _ => "⬜",
    };

    private void OpenInMonitor(System.Guid executionId) => this.Nav.NavigateTo($"/monitor/{executionId}");

    private static string Duration(ExecutionDto e)
        => e.CompletedAt is { } done ? $"{(done - e.StartedAt).TotalSeconds:F1}s" : "…";
}
