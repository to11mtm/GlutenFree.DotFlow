@namespace Workflow.UI.Client.Designer.Components
@using System.Globalization
@using Workflow.UI.Client.Designer.State
@inject IJSRuntime JS

<div class="df-canvas-viewport" @ref="viewportEl"
     @onpointerdown="OnViewportPointerDown"
     @onpointermove="OnViewportPointerMove"
     @onpointerup="OnViewportPointerUp"
     @onpointerleave="OnViewportPointerUp"
     @onwheel="OnWheel" @onwheel:preventDefault="true"
     style="cursor:@(panning ? "grabbing" : "grab");">
    <div class="df-canvas-content"
         style="transform: translate(@(T.PanX.ToString(Inv))px, @(T.PanY.ToString(Inv))px) scale(@(T.Zoom.ToString(Inv)));">
        <EdgeLayer Document="Document" />
        @foreach (var node in Document.Nodes)
        {
            <NodeView @key="node.Id" Node="node"
                      StateClass="@StateClassFor(node.Id)"
                      Selected="@IsSelected(node.Id)"
                      OnNodePointerDown="e => OnNodePointerDown.InvokeAsync((node, e))"
                      OnOutputPortPointerDown="p => OnOutputPortPointerDown.InvokeAsync((node, p))" />
        }
    </div>

    <div class="df-zoom-controls">
        <button class="df-btn" data-testid="zoom-in" @onclick="ZoomIn" @onclick:stopPropagation="true">＋</button>
        <button class="df-btn" data-testid="zoom-out" @onclick="ZoomOut" @onclick:stopPropagation="true">－</button>
        <button class="df-btn" data-testid="zoom-reset" @onclick="ResetZoom" @onclick:stopPropagation="true">@((int)(T.Zoom * 100))%</button>
        <button class="df-btn" data-testid="fit" @onclick="FitAsync" @onclick:stopPropagation="true">⤢ Fit</button>
    </div>
</div>

@code {
    private static readonly CultureInfo Inv = CultureInfo.InvariantCulture;

    private ElementReference viewportEl;
    private bool panning;
    private double panStartClientX, panStartClientY, panOriginX, panOriginY;

    /// <summary>The document to render.</summary>
    [Parameter, EditorRequired]
    public DesignerDocument Document { get; set; } = default!;

    /// <summary>The current transform (owned here; exposed for tests/overlays).</summary>
    [Parameter]
    public CanvasTransform Transform { get; set; } = CanvasTransform.Identity;

    /// <summary>Raised when the transform changes (two-way binding support).</summary>
    [Parameter]
    public EventCallback<CanvasTransform> TransformChanged { get; set; }

    /// <summary>Resolves an extra CSS state class for a node (run overlay).</summary>
    [Parameter]
    public Func<string, string>? NodeStateClass { get; set; }

    /// <summary>Returns whether a node id is selected (editing slices).</summary>
    [Parameter]
    public Func<string, bool>? NodeSelected { get; set; }

    /// <summary>Raised on node pointer-down (selection/move in editing slices).</summary>
    [Parameter]
    public EventCallback<(DesignerNode Node, PointerEventArgs Args)> OnNodePointerDown { get; set; }

    /// <summary>Raised on output-port pointer-down (connection drag in 3.3.b.2).</summary>
    [Parameter]
    public EventCallback<(DesignerNode Node, string Port)> OnOutputPortPointerDown { get; set; }

    private CanvasTransform T => this.Transform;

    private string StateClassFor(string nodeId) => this.NodeStateClass?.Invoke(nodeId) ?? string.Empty;

    private bool IsSelected(string nodeId) => this.NodeSelected?.Invoke(nodeId) ?? false;

    /// <summary>Fits all nodes into the viewport~ ⤢.</summary>
    public async Task FitAsync()
    {
        var (w, h) = await this.MeasureAsync();
        var bounds = new List<Rect>();
        foreach (var n in this.Document.Nodes)
        {
            bounds.Add(CanvasGeometry.NodeBounds(n.X, n.Y, NodePorts.Inputs(n).Count, NodePorts.Outputs(n).Count));
        }

        await this.SetTransform(CanvasGeometry.FitToContent(bounds, w, h));
    }

    private async Task<(double W, double H)> MeasureAsync()
    {
        try
        {
            var size = await JS.InvokeAsync<Size>("dotflowCanvas.measure", this.viewportEl);
            if (size.Width > 1 && size.Height > 1)
            {
                return (size.Width, size.Height);
            }
        }
        catch
        {
            // JS unavailable (e.g. tests) — fall through to a sensible default.
        }

        return (1200, 800);
    }

    private Task OnViewportPointerDown(PointerEventArgs e)
    {
        this.panning = true;
        this.panStartClientX = e.ClientX;
        this.panStartClientY = e.ClientY;
        this.panOriginX = this.Transform.PanX;
        this.panOriginY = this.Transform.PanY;
        return Task.CompletedTask;
    }

    private async Task OnViewportPointerMove(PointerEventArgs e)
    {
        if (!this.panning)
        {
            return;
        }

        var panX = this.panOriginX + (e.ClientX - this.panStartClientX);
        var panY = this.panOriginY + (e.ClientY - this.panStartClientY);
        await this.SetTransform(this.Transform with { PanX = panX, PanY = panY });
    }

    private void OnViewportPointerUp(PointerEventArgs e) => this.panning = false;

    private async Task OnWheel(WheelEventArgs e)
    {
        var factor = e.DeltaY < 0 ? 1.1 : 1 / 1.1;
        var newZoom = this.Transform.Zoom * factor;
        var next = CanvasGeometry.ZoomAboutCursor(new Point(e.OffsetX, e.OffsetY), this.Transform, newZoom);
        await this.SetTransform(next);
    }

    private Task ZoomIn() => this.SetTransform(this.ZoomAboutCentre(this.Transform.Zoom * 1.2));

    private Task ZoomOut() => this.SetTransform(this.ZoomAboutCentre(this.Transform.Zoom / 1.2));

    private Task ResetZoom() => this.SetTransform(this.ZoomAboutCentre(1.0));

    private CanvasTransform ZoomAboutCentre(double newZoom)
        => CanvasGeometry.ZoomAboutCursor(new Point(600, 400), this.Transform, newZoom);

    private async Task SetTransform(CanvasTransform t)
    {
        this.Transform = t;
        if (this.TransformChanged.HasDelegate)
        {
            await this.TransformChanged.InvokeAsync(t);
        }

        this.StateHasChanged();
    }

    private readonly record struct Size(double Width, double Height);
}
