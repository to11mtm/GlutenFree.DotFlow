@namespace Workflow.UI.Client.Designer.Components
@using System.Globalization
@using Workflow.UI.Client.Designer.State

<svg class="df-edges" style="width:@(Extent.W.ToString(Inv))px; height:@(Extent.H.ToString(Inv))px;">
    <defs>
        <marker id="df-arrow" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
            <path d="M0,0 L8,4 L0,8 Z" fill="var(--df-border)"></path>
        </marker>
        <marker id="df-arrow-sel" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
            <path d="M0,0 L8,4 L0,8 Z" fill="var(--df-accent)"></path>
        </marker>
    </defs>
    @foreach (var e in Edges)
    {
        var selected = Selection is not null && Selection.IsConnectionSelected(e.Key);
        <g class="df-edge-group">
            @if (Selection is not null)
            {
                <path class="df-edge-hit" d="@e.Path"
                      data-testid="edge-hit"
                      data-edge-key="@e.Key"
                      @onpointerdown="() => Select(e.Key)" @onpointerdown:stopPropagation="true"
                      @oncontextmenu="args => OnContextMenu(e.Key, args)" @oncontextmenu:stopPropagation="true" @oncontextmenu:preventDefault="true" />
            }
            <path class="df-edge @(selected ? "df-edge--selected" : string.Empty)" d="@e.Path"
                  fill="none" stroke="@(selected ? "var(--df-accent)" : "var(--df-border)")"
                  stroke-width="@(selected ? "3" : "2")"
                  marker-end="@(selected ? "url(#df-arrow-sel)" : "url(#df-arrow)")" />
            @if (!string.IsNullOrWhiteSpace(e.Condition))
            {
                @((MarkupString)LabelMarkup(e))
            }
        </g>
    }
</svg>

@code {
    private static readonly CultureInfo Inv = CultureInfo.InvariantCulture;

    /// <summary>The document whose connections to draw.</summary>
    [Parameter, EditorRequired]
    public DesignerDocument Document { get; set; } = default!;

    /// <summary>The current selection (null in read-only run mode → edges are not clickable).</summary>
    [Parameter]
    public SelectionState? Selection { get; set; }

    /// <summary>Raised on right-click of an edge (connection key + args).</summary>
    [Parameter]
    public EventCallback<(string Key, Microsoft.AspNetCore.Components.Web.MouseEventArgs Args)> OnConnectionContextMenu { get; set; }

    private void Select(string key) => this.Selection?.SelectConnection(key);

    private static string LabelMarkup(EdgeRender e)
        => System.FormattableString.Invariant(
            $"<text class=\"df-edge__label\" x=\"{e.LabelX}\" y=\"{e.LabelY}\" fill=\"var(--df-text-dim)\">{System.Net.WebUtility.HtmlEncode(e.Condition)}</text>");

    private Task OnContextMenu(string key, Microsoft.AspNetCore.Components.Web.MouseEventArgs args)
    {
        this.Selection?.SelectConnection(key);
        return this.OnConnectionContextMenu.InvokeAsync((key, args));
    }

    private (double W, double H) Extent
    {
        get
        {
            double maxX = 1000, maxY = 800;
            foreach (var n in Document.Nodes)
            {
                var b = CanvasGeometry.NodeBounds(n.X, n.Y, NodePorts.Inputs(n).Count, NodePorts.Outputs(n).Count);
                maxX = System.Math.Max(maxX, b.Right + 200);
                maxY = System.Math.Max(maxY, b.Bottom + 200);
            }

            return (maxX, maxY);
        }
    }

    private IEnumerable<EdgeRender> Edges
    {
        get
        {
            foreach (var c in Document.Connections)
            {
                var source = Document.FindNode(c.SourceNodeId);
                var target = Document.FindNode(c.TargetNodeId);
                if (source is null || target is null)
                {
                    continue;
                }

                var s = NodePorts.Anchor(source, c.SourcePortName, isOutput: true);
                var t = NodePorts.Anchor(target, c.TargetPortName, isOutput: false);
                yield return new EdgeRender(
                    c.Key,
                    CanvasGeometry.BezierPath(s, t),
                    string.IsNullOrWhiteSpace(c.Condition) ? null : c.Condition,
                    (s.X + t.X) / 2,
                    ((s.Y + t.Y) / 2) - 4);
            }
        }
    }

    private readonly record struct EdgeRender(string Key, string Path, string? Condition, double LabelX, double LabelY);
}

