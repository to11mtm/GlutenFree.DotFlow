@page "/designer/{Id}"
@namespace Workflow.UI.Client.Pages
@rendermode RenderModes.InteractiveWasm
@using System.Text.Json
@using Workflow.UI.Client.Designer.Components
@using Workflow.UI.Client.Designer.State
@using Workflow.UI.Client.Designer.State.Commands
@implements IAsyncDisposable
@inject Workflow.UI.Client.Api.WorkflowsClient Workflows
@inject Workflow.UI.Client.Api.ModulesClient Modules
@inject Workflow.UI.Client.Api.ExecutionsClient Executions
@inject Workflow.UI.Client.Api.RealTimeClient RealTime
@inject Workflow.UI.Client.Services.ToastService Toasts
@inject Workflow.UI.Client.Designer.State.DesignerClipboard Clipboard
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Designer · DotFlow</PageTitle>

<TopBar Subtitle="@(document?.Name)">
    @if (commands is not null && runState is null)
    {
        <button class="df-btn df-btn--primary" data-testid="save" @onclick="Save">💾 Save</button>
        <button class="df-btn" data-testid="undo" disabled="@(!commands.CanUndo)" title="@commands.UndoDescription" @onclick="() => commands.Undo()">↩</button>
        <button class="df-btn" data-testid="redo" disabled="@(!commands.CanRedo)" title="@commands.RedoDescription" @onclick="() => commands.Redo()">↪</button>
        <button class="df-btn" data-testid="run" @onclick="OpenRunDialog">▶ Run</button>
        <button class="df-btn" data-testid="history" @onclick="ToggleHistory">🕘 History</button>
        <span class="df-topbar__dirty" data-testid="dirty">@(commands.IsDirty ? "●unsaved" : "")</span>
    }
    else if (runState is not null)
    {
        <span class="df-topbar__runmode">▶ RUN</span>
    }
</TopBar>
<ToastHost />

@if (loading)
{
    <div class="df-empty">Loading workflow…</div>
}
else if (loadError is not null)
{
    <div class="df-empty">
        @loadError <button class="df-btn" @onclick="Load">Retry</button>
    </div>
}
else if (document is not null)
{
    <div class="df-designer">
        <div class="df-designer__body">
            @if (runState is null)
            {
                <div class="df-designer__palette">
                    @if (showHistory && document.Id != System.Guid.Empty)
                    {
                        <ExecutionHistory WorkflowId="document.Id" SelectedId="null" OnSelect="InspectExecution" />
                    }
                    else
                    {
                        <ModulePalette />
                    }
                </div>
                <div class="df-designer__canvas">
                    <CanvasView @ref="canvas" Document="document"
                                Selection="selection" Commands="commands"
                                OnDropModule="OnDropModule"
                                OnNodeContextMenu="OnNodeContextMenu"
                                OnConnectionContextMenu="OnConnectionContextMenu"
                                OnCanvasContextMenu="OnCanvasContextMenu" />
                </div>
                <div class="df-designer__props">
                    <PropertiesPanel Document="document" Selection="selection" Commands="commands" />
                </div>
            }
            else
            {
                <div class="df-designer__canvas">
                    <CanvasView @ref="canvas" Document="document" NodeStateClass="runState.CssClassFor" />
                </div>
                <div class="df-designer__props">
                    <RunOverlay Document="document" Run="runState" Reconnecting="reconnecting" OnCancel="CancelRun" OnClose="CloseRun" OnRerun="Rerun" OnJumpTo="JumpTo" />
                </div>
            }
        </div>
        <StatusBar Document="document" Issues="issues" ExtraInfo="@(runState is null ? statusInfo : "run mode (read-only)")" />
    </div>

    @if (showRunDialog)
    {
        <div class="df-modal-backdrop" @onclick="() => showRunDialog = false">
            <div class="df-modal" @onclick:stopPropagation="true" data-testid="run-dialog">
                <div class="df-label">Run inputs (JSON)</div>
                <textarea class="df-textarea" @bind="runInputs" data-testid="run-inputs"></textarea>
                <div class="df-row" style="margin-top: var(--df-space-3);">
                    <button class="df-btn df-btn--primary" data-testid="run-start" @onclick="StartRun">Start</button>
                    <button class="df-btn" @onclick="() => showRunDialog = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    <ContextMenu Visible="menuVisible" X="menuX" Y="menuY" Items="menuItems" OnClose="() => menuVisible = false" />

    @if (renameNodeId is not null)
    {
        <div class="df-modal-backdrop" @onclick="() => renameNodeId = null">
            <div class="df-modal" @onclick:stopPropagation="true">
                <div class="df-label">Rename node</div>
                <input class="df-input" @bind="renameValue" data-testid="rename-input" />
                <div class="df-row" style="margin-top: var(--df-space-3);">
                    <button class="df-btn df-btn--primary" data-testid="rename-ok" @onclick="ConfirmRename">OK</button>
                    <button class="df-btn" @onclick="() => renameNodeId = null">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (showSaveDialog)
    {
        <div class="df-modal-backdrop" @onclick="() => showSaveDialog = false">
            <div class="df-modal" @onclick:stopPropagation="true" data-testid="save-dialog">
                <div class="df-label">Cannot save — fix these first:</div>
                <ul class="df-issue-list">
                    @foreach (var issue in saveIssues)
                    {
                        <li class="df-issue df-issue--@issue.Severity">
                            @issue.Message
                            @if (issue.NodeId is not null)
                            {
                                <button class="df-link" @onclick="() => JumpTo(issue.NodeId)">→ @issue.NodeId</button>
                            }
                        </li>
                    }
                </ul>
                <button class="df-btn" @onclick="() => showSaveDialog = false">Close</button>
            </div>
        </div>
    }
}

@code {
    private CanvasView? canvas;
    private DesignerDocument? document;
    private CommandStack? commands;
    private readonly SelectionState selection = new();
    private readonly HashSet<string> knownModuleIds = new();
    private readonly Dictionary<string, ModuleSchemaDto?> schemaCache = new(System.StringComparer.Ordinal);
    private IReadOnlyList<GraphIssue> issues = System.Array.Empty<GraphIssue>();
    private bool loading = true;
    private string? loadError;
    private readonly string statusInfo = "editing";
    private DotNetObjectReference<Designer>? keysRef;

    private bool menuVisible;
    private double menuX, menuY;
    private IReadOnlyList<ContextMenu.MenuItem> menuItems = System.Array.Empty<ContextMenu.MenuItem>();

    private string? renameNodeId;
    private string renameValue = string.Empty;

    private bool showSaveDialog;
    private List<SaveIssue> saveIssues = new();

    // Run mode.
    private RunState? runState;
    private bool showRunDialog;
    private string runInputs = "{}";
    private bool reconnecting;
    private System.Threading.CancellationTokenSource? pollCts;
    private bool showHistory;

    private sealed record SaveIssue(string Severity, string Message, string? NodeId);

    /// <summary>The workflow id from the route (or <c>new</c>).</summary>
    [Parameter]
    public string Id { get; set; } = string.Empty;

    protected override Task OnParametersSetAsync() => this.Load();

    private async Task Load()
    {
        this.loading = true;
        this.loadError = null;
        try
        {
            var modules = await Modules.ListAsync();
            this.knownModuleIds.Clear();
            foreach (var m in modules)
            {
                this.knownModuleIds.Add(m.Id);
            }

            if (string.Equals(this.Id, "new", System.StringComparison.OrdinalIgnoreCase))
            {
                this.document = DesignerDocument.NewBlank("Untitled workflow");
            }
            else if (System.Guid.TryParse(this.Id, out var guid))
            {
                var dto = await Workflows.GetAsync(guid);
                foreach (var node in dto.Nodes)
                {
                    await this.EnsureSchema(node.ModuleId);
                }

                this.document = DesignerDocument.FromDto(dto, mid => this.schemaCache.TryGetValue(mid, out var s) ? s : null);
            }
            else
            {
                this.loadError = $"Invalid workflow id '{this.Id}'.";
                return;
            }

            this.commands = new CommandStack(this.document);
            this.commands.Changed += this.OnDocumentChanged;
            this.selection.Changed += this.OnSelectionChanged;
            this.Revalidate();

            // Deep link: /designer/{id}?execution={executionId} opens history mode.
            var query = new System.Uri(Nav.Uri).Query;
            if (query.Contains("execution=", System.StringComparison.OrdinalIgnoreCase))
            {
                var raw = query.Split(new[] { "execution=" }, System.StringSplitOptions.None)[1].Split('&')[0];
                if (System.Guid.TryParse(System.Uri.UnescapeDataString(raw), out var execId))
                {
                    await this.InspectExecution(execId);
                }
            }
        }
        catch (Workflow.UI.Client.Api.ApiException ex)
        {
            this.loadError = ex.Error.Summarize();
        }
        finally
        {
            this.loading = false;
        }
    }

    private async Task<ModuleSchemaDto?> EnsureSchema(string moduleId)
    {
        if (this.schemaCache.TryGetValue(moduleId, out var cached))
        {
            return cached;
        }

        var details = await Modules.GetAsync(moduleId);
        this.schemaCache[moduleId] = details?.Schema;
        return details?.Schema;
    }

    private async Task OnDropModule((string ModuleId, Point CanvasPoint) drop)
    {
        if (this.document is null || this.commands is null)
        {
            return;
        }

        // 🪄 Dropping a Fan In onto a node's output side auto-wires ALL of that node's outputs.
        if (drop.ModuleId == DropZones.FanInModuleId)
        {
            var target = DropZones.HitTestOutputSide(this.document, drop.CanvasPoint);
            if (target is not null)
            {
                await this.FanInAllOutputs(target);
                return;
            }
        }

        // 🔁🛡️ Dropping a loop / try-catch from the palette scaffolds its skeleton (empty body);
        // on a node's output side it is also wired from that node's primary output (UX-S4)~
        if (drop.ModuleId is "builtin.loop.foreach" or "builtin.loop.while")
        {
            await this.InsertLoopSkeleton(drop.CanvasPoint, drop.ModuleId, DropZones.HitTestOutputSide(this.document, drop.CanvasPoint));
            return;
        }

        if (drop.ModuleId == "builtin.trycatch")
        {
            await this.InsertTryCatchSkeleton(drop.CanvasPoint, DropZones.HitTestOutputSide(this.document, drop.CanvasPoint));
            return;
        }

        var schema = await this.EnsureSchema(drop.ModuleId);
        var existing = new HashSet<string>();
        foreach (var n in this.document.Nodes)
        {
            existing.Add(n.Id);
        }

        // 🔗 UX-R2: dropping any ordinary module on a node's output side wires it in
        // (source primary output → the new node's first input), as one undoable action~
        var wireSource = DropZones.HitTestOutputSide(this.document, drop.CanvasPoint);

        var node = new DesignerNode
        {
            Id = NodeIdGenerator.Generate(drop.ModuleId, existing),
            ModuleId = drop.ModuleId,
            Name = DisplayNameFor(drop.ModuleId),
            X = wireSource is null ? drop.CanvasPoint.X : wireSource.X + CanvasGeometry.NodeWidth + 80,
            Y = wireSource is null ? drop.CanvasPoint.Y : wireSource.Y,
            Schema = schema,
        };

        if (schema is not null)
        {
            foreach (var prop in schema.Properties)
            {
                if (prop.DefaultValue is JsonElement def)
                {
                    node.Properties[prop.Name] = def;
                }
            }
        }

        if (wireSource is null)
        {
            this.commands.Execute(new AddNodeCommand(node));
            return;
        }

        this.commands.Execute(new CompositeCommand($"Add {node.Name} (wired)", new List<IDesignerCommand>
        {
            new AddNodeCommand(node),
            new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = wireSource.Id,
                SourcePortName = PrimaryOutput(wireSource),
                TargetNodeId = node.Id,
                TargetPortName = NodePorts.Inputs(node)[0],
            }),
        }));
        this.selection.SelectNode(node.Id);
        Toasts.Success($"{node.Name} wired from {wireSource.Name}");
    }

    /// <summary>
    /// Adds a Fan In (mode=named → one object keyed by port name) to the right of the node and
    /// connects EVERY output port of the node into it, as one undoable action~ 🪄.
    /// </summary>
    private async Task FanInAllOutputs(DesignerNode source)
    {
        if (this.commands is null || this.document is null)
        {
            return;
        }

        var schema = await this.EnsureSchema("builtin.fanin");
        var existing = new HashSet<string>(this.document.Nodes.Select(n => n.Id));
        var fanIn = new DesignerNode
        {
            Id = NodeIdGenerator.Generate("builtin.fanin", existing),
            ModuleId = "builtin.fanin",
            Name = "Merge",
            X = source.X + CanvasGeometry.NodeWidth + 80,
            Y = source.Y,
            Schema = schema,
        };

        // Distinct ports of one node → 'named' keys the result by port ({ success: …, error: … })~
        fanIn.Properties["mode"] = System.Text.Json.JsonSerializer.SerializeToElement("named");

        var targetPort = schema is { Inputs.Count: > 0 } ? schema.Inputs[0].Name : "branches";
        var children = new List<IDesignerCommand> { new AddNodeCommand(fanIn) };
        foreach (var port in NodePorts.Outputs(source))
        {
            children.Add(new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = source.Id,
                SourcePortName = port,
                TargetNodeId = fanIn.Id,
                TargetPortName = targetPort,
            }));
        }

        this.commands.Execute(new CompositeCommand("Fan in all outputs", children));
        this.selection.SelectNode(fanIn.Id);
        Toasts.Success($"Merged {NodePorts.Outputs(source).Count} outputs of {source.Name} into one object (named mode)");
    }

    // ─── Context menu ────────────────────────────────────────────────────────────

    private void OnNodeContextMenu((DesignerNode Node, MouseEventArgs Args) e)
    {
        if (!this.selection.IsNodeSelected(e.Node.Id))
        {
            this.selection.SelectNode(e.Node.Id);
        }

        var node = e.Node;
        var items = new List<ContextMenu.MenuItem>
        {
            new("rename", "Rename", () => { this.BeginRename(node); return Task.CompletedTask; }),
            new("duplicate", "Duplicate", () => { this.Duplicate(node); return Task.CompletedTask; }),
            new("delete", "Delete", () => { this.DeleteSelected(); return Task.CompletedTask; }, Danger: true),
        };

        if (this.selection.Nodes.Count >= 2)
        {
            items.Insert(2, new("merge-fanin", "Merge outputs → Fan In", () => this.MergeSelectedOutputs()));
        }

        this.menuItems = items;
        this.ShowMenu(e.Args);
    }

    private void OnConnectionContextMenu((string Key, MouseEventArgs Args) e)
    {
        this.selection.SelectConnection(e.Key);
        this.menuItems = new List<ContextMenu.MenuItem>
        {
            new("delete", "Delete connection", () => { this.DeleteSelected(); return Task.CompletedTask; }, Danger: true),
        };
        this.ShowMenu(e.Args);
    }

    private void OnCanvasContextMenu(MouseEventArgs e)
    {
        // Convert the right-click point through the live canvas transform for snippet placement~
        var at = this.canvas is not null
            ? CanvasGeometry.ScreenToCanvas(new Point(e.OffsetX, e.OffsetY), this.canvas.Transform)
            : new Point(e.OffsetX, e.OffsetY);

        this.menuItems = new List<ContextMenu.MenuItem>
        {
            new("select-all", "Select all", () => { this.selection.SelectAll(this.document!); return Task.CompletedTask; }),
            new("paste", "Paste", () => { this.Paste(); return Task.CompletedTask; }),
            new("loop-skeleton", "Insert loop skeleton", () => this.InsertLoopSkeleton(at)),
            new("trycatch-skeleton", "Insert try/catch skeleton", () => this.InsertTryCatchSkeleton(at)),
            new("fit", "Fit to screen", async () => { if (this.canvas is not null) { await this.canvas.FitAsync(); } }),
        };
        this.ShowMenu(e);
    }

    private void ShowMenu(MouseEventArgs e)
    {
        this.menuX = e.ClientX;
        this.menuY = e.ClientY;
        this.menuVisible = true;
    }

    // ─── Edit operations ─────────────────────────────────────────────────────────

    private void DeleteSelected()
    {
        if (this.commands is null || this.document is null)
        {
            return;
        }

        if (this.selection.Nodes.Count == 0 && this.selection.Connections.Count == 0)
        {
            return;
        }

        var children = new List<IDesignerCommand>();
        if (this.selection.Nodes.Count > 0)
        {
            children.Add(new RemoveNodesCommand(this.selection.Nodes.ToList()));
        }

        if (this.selection.Connections.Count > 0)
        {
            children.Add(new RemoveConnectionsCommand(this.selection.Connections.ToList()));
        }

        if (children.Count == 1)
        {
            this.commands.Execute(children[0]);
        }
        else
        {
            this.commands.Execute(new CompositeCommand("Delete selection", children));
        }

        this.selection.Prune(this.document);
    }

    private void Duplicate(DesignerNode node)
    {
        if (this.commands is null || this.document is null)
        {
            return;
        }

        var existing = new HashSet<string>(this.document.Nodes.Select(n => n.Id));
        var clone = node.Clone();
        clone.Id = NodeIdGenerator.Generate(node.ModuleId, existing);
        clone.X = node.X + 40;
        clone.Y = node.Y + 40;
        this.commands.Execute(new AddNodeCommand(clone));
    }

    /// <summary>
    /// Adds a Fan In node (mode=merge → one composite object) to the right of the selected nodes
    /// and connects each node's first output to it, as a single undoable action~ 🪄.
    /// </summary>
    private async Task MergeSelectedOutputs()
    {
        if (this.commands is null || this.document is null || this.selection.Nodes.Count < 2)
        {
            return;
        }

        var sources = this.selection.Nodes
            .Select(id => this.document.FindNode(id))
            .Where(n => n is not null)
            .Select(n => n!)
            .OrderBy(n => n.Y)
            .ToList();
        if (sources.Count < 2)
        {
            return;
        }

        var schema = await this.EnsureSchema("builtin.fanin");
        var existing = new HashSet<string>(this.document.Nodes.Select(n => n.Id));
        var fanIn = new DesignerNode
        {
            Id = NodeIdGenerator.Generate("builtin.fanin", existing),
            ModuleId = "builtin.fanin",
            Name = "Merge",
            X = sources.Max(n => n.X) + CanvasGeometry.NodeWidth + 80,
            Y = sources.Average(n => n.Y),
            Schema = schema,
        };
        fanIn.Properties["mode"] = System.Text.Json.JsonSerializer.SerializeToElement("merge");

        var targetPort = schema is { Inputs.Count: > 0 } ? schema.Inputs[0].Name : "branches";
        var children = new List<IDesignerCommand> { new AddNodeCommand(fanIn) };
        foreach (var source in sources)
        {
            var outputs = NodePorts.Outputs(source);
            var sourcePort = outputs.Contains("success") ? "success" : outputs[0];
            children.Add(new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = source.Id,
                SourcePortName = sourcePort,
                TargetNodeId = fanIn.Id,
                TargetPortName = targetPort,
            }));
        }

        this.commands.Execute(new CompositeCommand("Merge outputs", children));
        this.selection.SelectNode(fanIn.Id);
        Toasts.Success($"Merged outputs of {sources.Count} nodes into one object (merge mode)");
    }

    private void Copy()
    {
        if (this.document is not null && this.selection.Nodes.Count > 0)
        {
            this.Clipboard.Copy(this.document, this.selection.Nodes);
        }
    }

    private void Paste()
    {
        if (this.commands is null || this.document is null || !this.Clipboard.HasContent)
        {
            return;
        }

        var existing = new HashSet<string>(this.document.Nodes.Select(n => n.Id));
        var (nodes, conns) = this.Clipboard.BuildPaste(existing);
        var children = new List<IDesignerCommand>();
        foreach (var n in nodes)
        {
            children.Add(new AddNodeCommand(n));
        }

        foreach (var c in conns)
        {
            children.Add(new AddConnectionCommand(c));
        }

        if (children.Count > 0)
        {
            this.commands.Execute(new CompositeCommand("Paste", children));
            this.selection.SetNodes(nodes.Select(n => n.Id));
        }
    }

    private void BeginRename(DesignerNode node)
    {
        this.renameNodeId = node.Id;
        this.renameValue = node.Name;
    }

    private void ConfirmRename()
    {
        if (this.commands is not null && this.renameNodeId is not null && this.document is not null)
        {
            var node = this.document.FindNode(this.renameNodeId);
            if (node is not null && node.Name != this.renameValue)
            {
                this.commands.Execute(new RenameNodeCommand(node.Id, node.Name, this.renameValue));
            }
        }

        this.renameNodeId = null;
    }

    private void JumpTo(string nodeId)
    {
        this.selection.SelectNode(nodeId);
        this.showSaveDialog = false;
    }

    // ─── Run mode (3.3.c.0 / c.1) ────────────────────────────────────────────────

    private void OpenRunDialog() => this.showRunDialog = true;

    private void ToggleHistory() => this.showHistory = !this.showHistory;

    private async Task InspectExecution(System.Guid executionId)
    {
        this.showHistory = false;
        try
        {
            var status = await Executions.GetStatusAsync(executionId);
            var run = new RunState { ExecutionId = executionId };
            run.SetTotalNodes(this.document?.Nodes.Count ?? 0);
            if (status is not null)
            {
                run.SeedFromSnapshot(status.State, status.Progress, status.NodeStates, status.Error);
            }

            run.Changed += this.OnRunChanged;
            this.runState = run;
        }
        catch (Workflow.UI.Client.Api.ApiException ex)
        {
            Toasts.Error(ex.Error.Summarize());
        }
    }

    private async Task Rerun()
    {
        await this.CloseRun();
        this.OpenRunDialog();
    }

    private async Task StartRun()
    {
        if (this.document is null)
        {
            return;
        }

        this.showRunDialog = false;

        Dictionary<string, JsonElement> inputs;
        try
        {
            inputs = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(
                string.IsNullOrWhiteSpace(this.runInputs) ? "{}" : this.runInputs) ?? new();
        }
        catch (JsonException)
        {
            Toasts.Error("Run inputs must be a valid JSON object.");
            return;
        }

        try
        {
            var started = await Executions.ExecuteAsync(this.document.Id, inputs);
            this.runState = new RunState { ExecutionId = started.ExecutionId };
            this.runState.SetTotalNodes(this.document.Nodes.Count);
            this.runState.Changed += this.OnRunChanged;
            this.runState.AddLog("execution started");

            // Subscribe to live events (c.1). Best-effort — the overlay still shows start state if the hub is down.
            await this.SubscribeRealTime(started.ExecutionId);
        }
        catch (Workflow.UI.Client.Api.ApiException ex)
        {
            Toasts.Error(ex.Error.Summarize());
        }
    }

    private async Task SubscribeRealTime(Guid executionId)
    {
        this.WireRealTimeHandlers();
        try
        {
            await RealTime.SubscribeToExecutionAsync(executionId);
        }
        catch
        {
            Toasts.Warning("Live updates unavailable — falling back to polling.");
            this.StartPolling(executionId);
        }
    }

    private void StartPolling(Guid executionId)
    {
        this.pollCts?.Cancel();
        this.pollCts = new System.Threading.CancellationTokenSource();
        var ct = this.pollCts.Token;
        _ = Task.Run(async () =>
        {
            while (!ct.IsCancellationRequested && this.runState is { IsTerminal: false })
            {
                try
                {
                    await Task.Delay(2000, ct);
                    var status = await Executions.GetStatusAsync(executionId, ct);
                    if (status is not null && this.runState is not null)
                    {
                        this.runState.SeedFromSnapshot(status.State, status.Progress, status.NodeStates, status.Error);
                    }
                }
                catch (System.OperationCanceledException)
                {
                    break;
                }
                catch
                {
                    // transient — keep polling until terminal or cancelled.
                }
            }
        });
    }

    private bool realTimeWired;

    private void WireRealTimeHandlers()
    {
        if (this.realTimeWired)
        {
            return;
        }

        this.realTimeWired = true;
        RealTime.ExecutionSnapshot += e => this.runState?.SeedFromSnapshot(e.State, e.Progress, e.NodeStates, e.Error);
        RealTime.NodeStarted += e => this.runState?.NodeStarted(e.NodeId);
        RealTime.NodeCompleted += e => this.runState?.NodeCompleted(e.NodeId, e.DurationMs);
        RealTime.NodeFailed += e => this.runState?.NodeFailed(e.NodeId, e.Error, e.DurationMs);
        RealTime.ExecutionProgress += e => this.runState?.Progress(e.Percentage, e.CurrentNode, e.CompletedNodes, e.TotalNodes);
        RealTime.ExecutionCompleted += e => this.runState?.MarkCompleted(e.DurationMs);
        RealTime.ExecutionFailed += e => this.runState?.MarkFailed(e.Error, e.DurationMs);
        RealTime.Reconnecting += () => { this.reconnecting = true; this.InvokeAsync(this.StateHasChanged); };
        RealTime.Reconnected += () => { this.reconnecting = false; this.InvokeAsync(this.StateHasChanged); };
    }

    private async Task CancelRun()
    {
        if (this.runState is null)
        {
            return;
        }

        try
        {
            await Executions.CancelAsync(this.runState.ExecutionId);
            this.runState.MarkCancelled();
        }
        catch (Workflow.UI.Client.Api.ApiException ex)
        {
            Toasts.Error(ex.Error.Summarize());
        }
    }

    private async Task CloseRun()
    {
        this.pollCts?.Cancel();
        if (this.runState is not null)
        {
            this.runState.Changed -= this.OnRunChanged;
            this.runState = null;
        }

        try
        {
            await RealTime.UnsubscribeAsync();
        }
        catch
        {
            // ignore~
        }
    }

    private void OnRunChanged() => this.InvokeAsync(this.StateHasChanged);

    // ─── Keyboard shortcuts (called from keys.js) ────────────────────────────────

    /// <summary>Handles a window-level shortcut forwarded by keys.js~ ⌨️.</summary>
    /// <param name="key">The key.</param>
    /// <param name="ctrl">Whether Ctrl/Cmd was held.</param>
    /// <param name="shift">Whether Shift was held.</param>
    /// <returns>A task.</returns>
    [JSInvokable]
    public async Task OnShortcut(string key, bool ctrl, bool shift)
    {
        if (this.commands is null || this.document is null)
        {
            return;
        }

        var k = key.ToLowerInvariant();
        if (ctrl && k == "z" && !shift)
        {
            this.commands.Undo();
        }
        else if (ctrl && (k == "y" || (k == "z" && shift)))
        {
            this.commands.Redo();
        }
        else if (ctrl && k == "a")
        {
            this.selection.SelectAll(this.document);
        }
        else if (ctrl && k == "c")
        {
            this.Copy();
        }
        else if (ctrl && k == "v")
        {
            this.Paste();
        }
        else if (ctrl && k == "s")
        {
            await this.Save();
        }
        else if (k is "delete" or "backspace")
        {
            this.DeleteSelected();
        }

        await this.InvokeAsync(this.StateHasChanged);
    }

    // ─── Save pipeline (D5/D14/Q5) ───────────────────────────────────────────────

    private async Task Save()
    {
        if (this.document is null || this.commands is null)
        {
            return;
        }

        // Stage 1: client structural gate.
        var clientErrors = this.issues.Where(i => i.Severity == IssueSeverity.Error).ToList();
        if (clientErrors.Count > 0)
        {
            this.saveIssues = clientErrors.Select(i => new SaveIssue("error", i.Message, i.NodeId)).ToList();
            this.showSaveDialog = true;
            return;
        }

        // Stage 2: authoritative server validate (degrade gracefully if unavailable).
        try
        {
            var vr = await Workflows.ValidateAsync(this.document.ToDto());
            if (!vr.Valid)
            {
                this.saveIssues = vr.Issues.Select(i => new SaveIssue(i.Severity, i.Message, i.NodeId)).ToList();
                this.showSaveDialog = true;
                return;
            }
        }
        catch (Workflow.UI.Client.Api.ApiException)
        {
            Toasts.Warning("Server validation unavailable — saving with client checks only.");
        }

        // Stage 3: persist.
        try
        {
            if (this.document.Id == System.Guid.Empty)
            {
                var created = await Workflows.CreateAsync(this.document.ToDto());
                this.commands.MarkSaved();
                Toasts.Success("Workflow created");
                Nav.NavigateTo($"/designer/{created.Id}");
            }
            else
            {
                await Workflows.UpdateAsync(this.document.ToDto());
                this.commands.MarkSaved();
                Toasts.Success("Workflow saved");
            }
        }
        catch (Workflow.UI.Client.Api.ApiException ex)
        {
            this.saveIssues = new List<SaveIssue> { new("error", ex.Error.Summarize(), null) };
            this.showSaveDialog = true;
        }
    }

    /// <summary>
    /// UX-F4.5/S4 — Inserts a loop (For Each / While) + placeholder body step wired
    /// <c>loopBody → input</c>, as one undoable action. When <paramref name="source"/> is given
    /// (output-side drop), the loop is placed right of it and wired from its primary output into
    /// the loop's conventional input (<c>collection</c> / <c>condition</c>)~ 🔁.
    /// </summary>
    private async Task InsertLoopSkeleton(Point at, string moduleId = "builtin.loop.foreach", DesignerNode? source = null)
    {
        if (this.commands is null || this.document is null)
        {
            return;
        }

        var loopSchema = await this.EnsureSchema(moduleId);
        var bodySchema = await this.EnsureSchema("builtin.passthrough");
        var existing = new HashSet<string>(this.document.Nodes.Select(n => n.Id));

        var origin = source is null ? at : new Point(source.X + CanvasGeometry.NodeWidth + 80, source.Y);
        var loop = new DesignerNode
        {
            Id = NodeIdGenerator.Generate(moduleId, existing),
            ModuleId = moduleId,
            Name = moduleId == "builtin.loop.while" ? "While" : "For Each",
            X = origin.X,
            Y = origin.Y,
            Schema = loopSchema,
        };
        existing.Add(loop.Id);

        var body = new DesignerNode
        {
            Id = NodeIdGenerator.Generate("builtin.passthrough", existing),
            ModuleId = "builtin.passthrough",
            Name = "Body step (replace me)",
            X = origin.X + CanvasGeometry.NodeWidth + 80,
            Y = origin.Y,
            Schema = bodySchema,
        };

        var children = new List<IDesignerCommand>
        {
            new AddNodeCommand(loop),
            new AddNodeCommand(body),
            new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = loop.Id,
                SourcePortName = "loopBody",
                TargetNodeId = body.Id,
                TargetPortName = "input",
            }),
        };

        if (source is not null)
        {
            children.Add(new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = source.Id,
                SourcePortName = PrimaryOutput(source),
                TargetNodeId = loop.Id,
                TargetPortName = moduleId == "builtin.loop.while" ? "condition" : "collection",
            }));
        }

        this.commands.Execute(new CompositeCommand("Insert loop skeleton", children));
        this.selection.SetNodes(new[] { loop.Id, body.Id });
        Toasts.Success(source is null
            ? "Loop skeleton inserted — replace the body step, then continue the flow from 'done'"
            : $"Loop wired from {source.Name} — replace the body step, then continue from 'done'");
    }

    /// <summary>
    /// UX-F5.3/S4 — Inserts a Try Catch + placeholder try/catch steps wired from the <c>try</c>
    /// and <c>catch</c> routes, as one undoable action. When <paramref name="source"/> is given
    /// (output-side drop), the guard is placed right of it and wired from its primary output into
    /// the guard's <c>input</c> activation port~ 🛡️.
    /// </summary>
    private async Task InsertTryCatchSkeleton(Point at, DesignerNode? source = null)
    {
        if (this.commands is null || this.document is null)
        {
            return;
        }

        var tcSchema = await this.EnsureSchema("builtin.trycatch");
        var bodySchema = await this.EnsureSchema("builtin.passthrough");
        var existing = new HashSet<string>(this.document.Nodes.Select(n => n.Id));

        var origin = source is null ? at : new Point(source.X + CanvasGeometry.NodeWidth + 80, source.Y);
        var guard = new DesignerNode
        {
            Id = NodeIdGenerator.Generate("builtin.trycatch", existing),
            ModuleId = "builtin.trycatch",
            Name = "Try Catch",
            X = origin.X,
            Y = origin.Y,
            Schema = tcSchema,
        };
        existing.Add(guard.Id);

        var tryStep = new DesignerNode
        {
            Id = NodeIdGenerator.Generate("builtin.passthrough", existing),
            ModuleId = "builtin.passthrough",
            Name = "Try step (replace me)",
            X = origin.X + CanvasGeometry.NodeWidth + 80,
            Y = origin.Y,
            Schema = bodySchema,
        };
        existing.Add(tryStep.Id);

        var catchStep = new DesignerNode
        {
            Id = NodeIdGenerator.Generate("builtin.passthrough", existing),
            ModuleId = "builtin.passthrough",
            Name = "Catch step (replace me)",
            X = origin.X + CanvasGeometry.NodeWidth + 80,
            Y = origin.Y + 200,
            Schema = bodySchema,
        };

        var children = new List<IDesignerCommand>
        {
            new AddNodeCommand(guard),
            new AddNodeCommand(tryStep),
            new AddNodeCommand(catchStep),
            new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = guard.Id,
                SourcePortName = "try",
                TargetNodeId = tryStep.Id,
                TargetPortName = "input",
            }),
            new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = guard.Id,
                SourcePortName = "catch",
                TargetNodeId = catchStep.Id,
                TargetPortName = "input",
            }),
        };

        if (source is not null)
        {
            children.Add(new AddConnectionCommand(new DesignerConnection
            {
                SourceNodeId = source.Id,
                SourcePortName = PrimaryOutput(source),
                TargetNodeId = guard.Id,
                TargetPortName = "input",
            }));
        }

        this.commands.Execute(new CompositeCommand("Insert try/catch skeleton", children));
        this.selection.SetNodes(new[] { guard.Id, tryStep.Id, catchStep.Id });
        Toasts.Success(source is null
            ? "Try/catch skeleton inserted — replace the steps, then continue the flow from 'done'"
            : $"Try/catch wired from {source.Name} — replace the steps, then continue from 'done'");
    }

    /// <summary>The node's primary output port (prefers <c>success</c>, else the first)~ 🔌.</summary>
    private static string PrimaryOutput(DesignerNode node)
    {
        var outputs = NodePorts.Outputs(node);
        return outputs.Contains("success") ? "success" : outputs[0];
    }

    private static string DisplayNameFor(string moduleId)
    {
        var lastDot = moduleId.LastIndexOf('.');
        return lastDot >= 0 && lastDot < moduleId.Length - 1 ? moduleId[(lastDot + 1)..] : moduleId;
    }

    private void OnDocumentChanged()
    {
        this.Revalidate();
        _ = this.SyncDirty();
        this.InvokeAsync(this.StateHasChanged);
    }

    private async Task SyncDirty()
    {
        try
        {
            await JS.InvokeVoidAsync("dotflowKeys.setDirty", this.commands?.IsDirty ?? false);
        }
        catch
        {
            // JS not ready — ignore.
        }
    }

    private void OnSelectionChanged() => this.InvokeAsync(this.StateHasChanged);

    private void Revalidate()
    {
        if (this.document is not null)
        {
            this.issues = GraphValidator.Validate(this.document, this.knownModuleIds);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            this.keysRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("dotflowKeys.register", this.keysRef);
            }
            catch
            {
                // JS unavailable (tests) — shortcuts simply won't fire from the window.
            }

            if (this.canvas is not null && this.document is not null)
            {
                await this.canvas.FitAsync();
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (this.commands is not null)
        {
            this.commands.Changed -= this.OnDocumentChanged;
        }

        this.selection.Changed -= this.OnSelectionChanged;

        try
        {
            await JS.InvokeVoidAsync("dotflowKeys.unregister");
        }
        catch
        {
            // ignore~
        }

        this.keysRef?.Dispose();
    }
}
